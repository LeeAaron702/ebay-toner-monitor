# eBay Toner Arbitrage Monitor - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED - eBay API Credentials
# =============================================================================
# Get these from https://developer.ebay.com/my/keys
EBAY_APP_ID=your_client_id_here
EBAY_CLIENT_SECRET=your_client_secret_here

# =============================================================================
# REQUIRED - Telegram Bot Configuration  
# =============================================================================
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCDefGHIjklMNOPQRstUVWxyz

# Your chat/group ID (use @userinfobot to find it)
TELEGRAM_CHAT_ID=-1001234567890

# Public URL for webhook (use Cloudflare Tunnel, ngrok, etc.)
TELEGRAM_WEBHOOK_URL=https://your-domain.com/telegram/webhook

# Secret for webhook validation (min 32 characters)
TELEGRAM_WEBHOOK_SECRET=your_random_secret_string_min_32_chars

# =============================================================================
# OPTIONAL - Application Settings
# =============================================================================
# Polling interval in seconds (default: 60)
RUN_INTERVAL=60

# SQLite database path (default: database.db)
DB_PATH=database.db

# Zip code for eBay shipping estimates
ZIP_CODE=93012

# =============================================================================
# OPTIONAL - Security
# =============================================================================
# API key for /exclude/* endpoints (leave empty to disable auth)
EXCLUDE_API_KEY=

# =============================================================================
# OPTIONAL - AI Features
# =============================================================================
# Ollama server for AI-powered description parsing
OLLAMA_BASE_URL=http://ollama:11434

# =============================================================================
# OPTIONAL - Git Auto-Sync (Multi-Machine Deployment)
# =============================================================================
# Enable automatic git sync (commits and pushes 2x daily)
GIT_AUTO_SYNC=false

# Branch to sync to (default: main)
GIT_SYNC_BRANCH=main

# Remote name (default: origin)
GIT_REMOTE=origin

# Git commit author (used for auto-commits)
GIT_USER_NAME=Toner Monitor Bot
GIT_USER_EMAIL=bot@toner-monitor.local

# Machine identifier (appears in commit messages, helps identify which machine committed)
# Defaults to hostname if not set
MACHINE_ID=machine-1
